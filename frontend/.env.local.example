# ─── Enigma Invest — Frontend Environment Variables ─────────────────────────
# Copy this file to .env.local and fill in the values.
# All variables MUST be prefixed with VITE_ to be exposed to browser code.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash). Leave unset to use same-origin `/api/v1`
# (Vite dev server proxies `/api` → backend — no CORS issues).
# Only set this if the API is on another host, e.g. VITE_API_URL=https://api.example.com/api/v1
# VITE_API_URL=/api/v1

# Deployed InvestmentPlatform.sol contract address (fill after deployment)
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Target chain ID for MetaMask wallet switching
# 80002 = Polygon Amoy testnet
# 31337 = Local Hardhat node
VITE_CHAIN_ID=80002

# Block explorer base URL for tx hash links
VITE_POLYGONSCAN_URL=https://amoy.polygonscan.com/tx

# Application display name
VITE_APP_NAME=Enigma Invest

# ─── Stub / Demo Mode ────────────────────────────────────────────────────────
# Set to "true" to enable stub mode: skips MetaMask and posts investment
# with a generated fake txHash. Useful before contract is deployed.
VITE_STUB_MODE=false
