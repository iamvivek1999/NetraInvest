{
  "name": "enigma-invest-backend",
  "version": "1.0.0",
  "description": "Transparent Investment Platform - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "seed": "node src/scripts/seed-dev-data.js",
    "sync:abi": "node src/scripts/syncAbi.js",
    "lint": "eslint src/**/*.js",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --runInBand --forceExit --detectOpenHandles --coverage",
    "test:verbose": "jest --runInBand --forceExit --verbose",
    "seed:web3": "node src/scripts/dev-e2e-seed.js",
    "migrate": "node src/scripts/migrate-phase12.js",
    "migrate:dry": "node src/scripts/migrate-phase12.js --dry-run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "colors": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
