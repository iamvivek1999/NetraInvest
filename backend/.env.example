# ══════════════════════════════════════════════════════════════════════
#  Enigma Invest — Backend Environment Variables
#  UPDATED FOR LOCAL QA PREP
# ══════════════════════════════════════════════════════════════════════
#
#  SETUP INSTRUCTIONS FOR LOCAL DEV:
#    1. Copy this file:   cp .env.example .env/.env
#    2. Fill in all REQUIRED vars below.
#    3. For a minimal local QA run (no Razorpay, no blockchain):
#       set DEV_BYPASS_PAYMENT=true and DEV_SKIP_BLOCKCHAIN=true.
#
#  NOTE: The env file must be placed at  backend/.env/.env
#  (the config loader reads: src/config/env.js → ../../.env/.env)
#
# ─────────────────────────────────────────────────────────────────────
#  LEGEND:
#    [REQUIRED]    — server will NOT start without this
#    [OPTIONAL]    — feature degrades gracefully if missing
#    [DEV ONLY]    — must be false/unset in production
#    [BACKEND]     — used by backend only
#    [FRONTEND]    — used by frontend only
#    [BOTH]        — used by both
# ══════════════════════════════════════════════════════════════════════


# ─── Server ──────────────────────────────────────────────────────────
# [REQUIRED] [BACKEND]
PORT=5000
NODE_ENV=development        # use 'production' on live server


# ─── MongoDB ─────────────────────────────────────────────────────────
# [REQUIRED] [BACKEND]
# Get from: https://cloud.mongodb.com → Clusters → Connect
# For local dev: use a free Atlas M0 cluster or local mongod instance.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/enigma_invest?retryWrites=true&w=majority

# Local mongod alternative (no Atlas needed):
# MONGO_URI=mongodb://127.0.0.1:27017/enigma_invest


# ─── JWT ─────────────────────────────────────────────────────────────
# [REQUIRED] [BACKEND]
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_minimum_32_chars
JWT_EXPIRE=7d


# ─── CORS ────────────────────────────────────────────────────────────
# [OPTIONAL] [BACKEND]
# URL of the frontend dev server. Adjust if your frontend runs on a different port.
FRONTEND_URL=http://localhost:5173   # Vite default; use 3000 for CRA/Next


# ─── Razorpay ────────────────────────────────────────────────────────
# [OPTIONAL] [BACKEND]
# Required for REAL payment flows. Get from: https://dashboard.razorpay.com
# Use TEST mode keys for local development (prefix: rzp_test_).
# Leave blank and set DEV_BYPASS_PAYMENT=true for payment simulation.
RAZORPAY_KEY_ID=rzp_test_<your_key_id_here>
RAZORPAY_KEY_SECRET=<your_key_secret_here>

# [OPTIONAL] [FRONTEND]
# The public key sent to frontend for Razorpay checkout initialisation.
# Must match RAZORPAY_KEY_ID. Only needed if frontend reads from its own .env.
VITE_RAZORPAY_KEY_ID=rzp_test_<your_key_id_here>


# ─── Blockchain Transparency Layer ───────────────────────────────────
# [OPTIONAL] [BACKEND]
# All three values are required for real on-chain transparency logging.
# Leave blank to degrade gracefully (investment is recorded; blockchain log skipped).
# Get RPC from: https://dashboard.alchemy.com → Create App → Polygon Amoy

# Alchemy RPC endpoint (Polygon Amoy testnet recommended for dev):
ALCHEMY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/<your_alchemy_key>

# Throwaway backend wallet private key (NEVER use your personal/mainnet wallet):
# Create with: node -e "const {Wallet}=require('ethers');console.log(Wallet.createRandom().privateKey)"
ADMIN_WALLET_PRIVATE_KEY=0x_your_throwaway_wallet_private_key_here

# Deployed InvestmentLogger contract address (fill after Hardhat deployment):
INVESTMENT_LOGGER_CONTRACT_ADDRESS=0x_fill_after_deployment

# Legacy field (single InvestmentPlatform contract — kept for backwards compat):
CONTRACT_ADDRESS=0x_fill_after_deployment


# ─── Admin Seed Credentials ──────────────────────────────────────────
# [OPTIONAL] [BACKEND]
# Used by seed-dev-data.js and Postman JWT generation helpers.
# For local QA the seed script uses admin@test.com / Pass1234 (hardcoded).
ADMIN_EMAIL=admin@enigmainvest.dev
ADMIN_PASSWORD=Admin@1234


# ══════════════════════════════════════════════════════════════════════
#  DEV-ONLY FLAGS  —  NEVER SET THESE TO true IN PRODUCTION
# ══════════════════════════════════════════════════════════════════════

# [DEV ONLY] [BACKEND]
# DEV_BYPASS_PAYMENT=true
#   Skips Razorpay signature verification entirely.
#   createOrder returns a fake order ID when Razorpay keys are absent.
#   verifyPayment accepts any signature without checking.
#   The investment record is STILL created (going through the full save path).
#   Duplicate protection (paymentOrderId idempotency) is STILL enforced.
#   Use for: testing invest flow end-to-end without real Razorpay account.
DEV_BYPASS_PAYMENT=true

# [DEV ONLY] [BACKEND]
# DEV_SKIP_BLOCKCHAIN=true
#   Returns a fake txHash/blockNumber instead of calling the RPC.
#   Investment is still saved; blockchainStatus is set to 'logged' with mock values.
#   Use for: testing payment success + "blockchain logged" path without an RPC.
#   Leave false (or unset) to test "blockchain failed" graceful degradation.
DEV_SKIP_BLOCKCHAIN=true
