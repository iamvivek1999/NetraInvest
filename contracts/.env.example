# ─── Polygon Amoy Testnet ────────────────────────────────────────────────────
# Get a free RPC URL from:
#   Alchemy:    https://dashboard.alchemy.com/
#   Infura:     https://infura.io/
#   QuickNode:  https://quicknode.com/
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Admin Wallet ─────────────────────────────────────────────────────────────
# The wallet that deploys the contract and acts as the on-chain operator.
# This is the same wallet address that backend uses to sign createCampaign
# and releaseMilestone transactions.
#
# WARNING: Never commit this file with a real private key.
# In production, use a hardware wallet or secrets manager.
ADMIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── Polygonscan (optional, for contract verification) ────────────────────────
# Get from: https://amoy.polygonscan.com/ → My Account → API Keys
# Only needed if you want to verify the contract source on-chain
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ─── Gas Reporter (optional) ──────────────────────────────────────────────────
REPORT_GAS=false
